{
  "manifest_version": 3,
  "name": "ClawFeel — Entropy Network",
  "description": "Contribute hardware entropy to the decentralized ClawFeel network",
  "version": "0.11.0",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://api.clawfeel.ai/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://clawfeel.ai/*", "https://www.clawfeel.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
