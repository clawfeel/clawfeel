{
  "name": "clawfeel",
  "version": "0.6.7",
  "description": "Your Claw's Heartbeat — hardware-entropy random number generator with security hardening",
  "type": "module",
  "main": "./scripts/sdk.mjs",
  "exports": {
    ".": "./scripts/sdk.mjs",
    "./sdk": "./scripts/sdk.mjs"
  },
  "bin": {
    "clawfeel": "./scripts/clawfeel.mjs"
  },
  "scripts": {
    "start": "node scripts/clawfeel.mjs",
    "feel": "node scripts/clawfeel.mjs --pretty",
    "digit": "node scripts/clawfeel.mjs --digit-only",
    "monitor": "node scripts/clawfeel.mjs --pretty --interval 5 --count 12",
    "broadcast": "node scripts/clawfeel.mjs --broadcast --interval 10 --count 999",
    "listen": "node scripts/clawfeel.mjs --listen",
    "relay": "node scripts/relay.mjs",
    "join": "node scripts/clawfeel.mjs --relay http://localhost:3415 --pretty --interval 5 --count 999"
  },
  "keywords": [
    "entropy",
    "random",
    "hardware",
    "sha256",
    "decentralized",
    "openclaw",
    "three-body",
    "security"
  ],
  "author": "ClawFeel",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clawfeel/clawfeel.git"
  },
  "homepage": "https://clawfeel.ai",
  "bugs": {
    "url": "https://github.com/clawfeel/clawfeel/issues"
  }
}
